{
  "name": "modulah-github-io",
  "version": "1.0.0",
  "description": "MoDuL's Torn Racing Hub - GitHub Pages site with userscripts and tools",
  "private": true,
  "scripts": {
    "lint:js": "eslint . --ext .js --ignore-pattern node_modules/",
    "lint:css": "stylelint '**/*.css' --ignore-path .gitignore",
    "lint:html": "htmlhint '**/*.html' --ignore .gitignore",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:fix": "eslint . --ext .js --fix && stylelint '**/*.css' --fix",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "format": "prettier --write '**/*.{js,css,html,json,md}'",
    "format:check": "prettier --check '**/*.{js,css,html,json,md}'",
    "security": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "prepare": "husky install"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "htmlhint": "^1.1.4",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/modulah/modulah.github.io.git"
  },
  "keywords": [
    "torn-racing",
    "userscripts",
    "github-pages"
  ],
  "author": "MoDuL",
  "license": "ALL-RIGHTS-RESERVED",
  "bugs": {
    "url": "https://github.com/modulah/modulah.github.io/issues"
  },
  "homepage": "https://modulah.github.io"
}
